{
  "manifest_version": 3,
  "name": "Workers AI Sidepanel",
  "version": "0.4.0",
  "description": "A Chrome side panel for OpenAI-compatible Workers AI chat endpoints.",
  "permissions": ["storage", "sidePanel", "activeTab", "scripting", "tabs"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Workers AI Sidepanel",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html"
}
